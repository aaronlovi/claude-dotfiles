# Machine-specific settings for Claude Code
# Copy this file to ~/.claude/.env and edit as needed.
#
# These values are referenced by CLAUDE.md and read by Claude at runtime.
# Do not commit ~/.claude/.env — it is git-ignored.

# Path to your Obsidian vault (used by pipeline commands for output)
OBSIDIAN_VAULT=/mnt/c/Users/aaron/ObsidianVaults/DevNotes

# Second Brain database settings are in scripts/second-brain/.env
# (separate configuration — see scripts/second-brain/.env.example)
